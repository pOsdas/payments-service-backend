# DB
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/test_backend
DB_ECHO=False
DB_ECHO_POOL=False
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_PRE_PING=True
DB_POOL_RECYCLE=600
DB_CREATE_RETRIES=10
DB_CREATE_RETRY_DELAY=2
ALLOW_DB_CREATE=1
POSTGRES_MAINTENANCE_DB=postgres

# BACKEND
DEBUG=False
SECRET_KEY=your_secret_key_here
ALLOWED_HOSTS=["localhost","127.0.0.1"]

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
OUTBOX_POLL_INTERVAL_SECONDS=2
OUTBOX_BATCH_SIZE=20

API_KEY=super-secret-test-api-key

PAYMENT_PROCESSING_MAX_ATTEMPTS=3
PAYMENT_PROCESSING_RETRY_BASE_DELAY_SECONDS=2